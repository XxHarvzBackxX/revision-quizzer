VITE_APP_NAME=Quiz Arcade
APP_ORIGIN=http://localhost:5173
CSRF_SECRET=replace-with-at-least-32-random-characters

# Public Firebase web-app configuration (safe to expose to the browser).
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=your-recaptcha-enterprise-site-key
VITE_FIRESTORE_REGION=your-firestore-region

# Enforce only after App Check is registered and verified in the deployment.
FIREBASE_APP_CHECK_ENFORCED=false

# Preferred: base64 encode the full Firebase service account JSON file.
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=base64-encoded-service-account-json

# Fallback: split service account values.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Two-year inactivity deletion and 30-day warning email.
CRON_SECRET=replace-with-a-random-vercel-cron-secret
RESEND_API_KEY=re_your_resend_api_key
RETENTION_FROM_EMAIL=Quiz Arcade <accounts@your-verified-domain.example>
