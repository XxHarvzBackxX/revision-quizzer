{
  "name": "quiz-arcade",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.api.json --noEmit",
    "content:generate": "node scripts/generate-curated-datasets.mjs",
    "content:audit": "node scripts/audit-curated-datasets.mjs",
    "revision:audit": "vitest run src/revision/registry.test.ts",
    "content:build": "node scripts/generate-curated-datasets.mjs && node scripts/audit-curated-datasets.mjs"
  },
  "dependencies": {
    "@vercel/node": "^5.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "firebase-admin": "^13.4.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
